# =====================================================================
# Mushola Nur Hidayah — Environment Variables
# Copy to .env.local for local dev, or set in Vercel Project Settings.
# Replace placeholder values with your real credentials.
# =====================================================================

# ---- AI (Gemini) ----
# Used by /api/generate-khutbah and /api/ask-ai endpoints.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ---- Public URL ----
# Where the app is hosted. Used for self-referential links and OAuth callbacks.
APP_URL="http://localhost:3000"

# ---- Supabase (client-side, exposed to browser via VITE_ prefix) ----
# Replace with your Supabase project URL & anon key.
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# ---- Supabase (server-side, NEVER expose to browser) ----
# Used by serverless functions for privileged operations.
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ---- Web Push (VAPID) ----
# Optional. If not set, the server will generate ephemeral keys at
# startup. For production, generate fixed keys (npx web-push generate-vapid-keys)
# and store them in the `system_config` Supabase table.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# ---- Optional: enable in-process node-cron for push notifications ----
# Set to "true" only for long-running processes (NOT Vercel serverless).
# On Vercel, use the cron entry in vercel.json to hit /api/push/trigger-cron.
ENABLE_NODE_CRON="false"
